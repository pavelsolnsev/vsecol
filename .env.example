# Скопируйте в .env.local для локальной разработки (файлы .env* не коммитить).

# Базовый URL бэкенда (со слэшем в конце или без — оба варианта допустимы).
NUXT_PUBLIC_API_URL=
# Совместимость со старым именем переменной:
# VITE_APP_API_URL=

# Публичный URL сайта для абсолютных ссылок (опционально; иначе берётся origin страницы).
NUXT_PUBLIC_SITE_URL=

# Прокси /api → бэкенд включается только если задан URL API выше.

# Аналитика и трекинг — оставьте пустым в демо; при пустых значениях скрипты не подключаются.
NUXT_PUBLIC_GTM_ID=
NUXT_PUBLIC_YANDEX_METRIKA_ID=
NUXT_PUBLIC_FB_PIXEL=

# Публичный URL S3/статики (если используется).
NUXT_PUBLIC_S3_BUCKET=
